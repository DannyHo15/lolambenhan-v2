# File: apps/web/Dockerfile (hoặc đặt ở root thư mục tùy cấu trúc)
FROM oven/bun:1-alpine AS builder
WORKDIR /app
RUN bun add -g turbo
COPY . .
RUN turbo prune --scope=@lolambenhan/web --docker

FROM oven/bun:1-alpine AS installer
WORKDIR /app
COPY --from=builder /app/out/json/ .
COPY --from=builder /app/out/bun.lock ./bun.lock
RUN bun install --frozen-lockfile
COPY --from=builder /app/out/full/ .
RUN bun run build --filter=@lolambenhan/web...

FROM oven/bun:1-alpine AS runner
WORKDIR /app
# Copy standalone output từ bước install
COPY --from=installer /app/apps/web/.next/standalone ./
COPY --from=installer /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=installer /app/apps/web/public ./apps/web/public

EXPOSE 3001
CMD ["node", "apps/web/server.js"]
