{
  "name": "@lolambenhan/api",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "dev:ws": "bun --watch src/ws-server.ts",
    "start": "bun run src/index.ts",
    "start:ws": "bun run src/ws-server.ts",
    "build": "bun build src/index.ts --target bun --outdir dist",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.3",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "cloudinary": "^2.9.0",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.22",
    "google-auth-library": "^10.5.0",
    "postgres": "^3.4.8",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "@types/node": "^25.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "drizzle-kit": "^0.31.8",
    "vitest": "^3.2.4"
  }
}
