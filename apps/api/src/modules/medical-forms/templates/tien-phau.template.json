    {
      "id": "cardiovascular-assessment",
      "name": "Đánh Giá Tim Mạch",
      "order": 4,
      "collapsible": false,
      "fields": [
        {
          "id": "heart-disease",
          "name": "heartDisease",
          "label": "Tiền Sử Bệnh Tim",
          "type": "checkbox",
          "order": 1,
          "required": true,
          "width": "full",
          "multiple": true,
          "columns": 2,
          "options": [
            { "value": "hypertension", "label": "Tăng huyết áp" },
            { "value": "coronary", "label": "Bệnh động mạch vành" },
            { "value": "arrhythmia", "label": "Rối loạn nhịp tim" },
            { "value": "heart-failure", "label": "Suy tim" },
            { "value": "valvular", "label": "Bệnh van tim" },
            { "value": "mi", "label": "Đã nhồi máu cơ tim" },
            { "value": "pacemaker", "label": "Máy tạo nhịp/Khử rung" },
            { "value": "none", "label": "Không có" }
          ]
