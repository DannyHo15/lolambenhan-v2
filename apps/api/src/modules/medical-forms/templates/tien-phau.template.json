          "order": 1,
          "required": true,
          "width": "full",
          "options": [
            {
              "value": "asa1",
              "label": "ASA I: Bệnh nhân khỏe mạnh, không có bệnh lý đi kèm"
            },
            {
              "value": "asa2",
              "label": "ASA II: Bệnh lý đi kèm nhẹ, không hạn chế sinh hoạt"
            },
            {
              "value": "asa3",
              "label": "ASA III: Bệnh lý đi kèm nặng, hạn chế sinh hoạt"
            },
            {
              "value": "asa4",
              "label": "ASA IV: Bệnh lý đi kèm đe dọa tính mạng, phẫu thuật cấp cứu"
            },
            {
              "value": "asa5",
              "label": "ASA V: Bệnh nhân sắp chết, không mong sống dù phẫu thuật"
            },
            {
              "value": "asa6",
              "label": "ASA VI: Bệnh nhân đã chết não để lấy tạng"
            }
