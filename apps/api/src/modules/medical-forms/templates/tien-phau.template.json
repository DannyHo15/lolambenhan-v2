          "order": 4,
          "required": true,
          "width": "third",
          "min": 8,
          "max": 35,
          "unit": "lần/phút"
        },
        {
          "id": "spo2",
          "name": "spo2",
          "label": "SpO2 (%)",
          "type": "number",
          "order": 5,
          "required": true,
          "width": "third",
          "min": 70,
          "max": 100,
          "unit": "%"
