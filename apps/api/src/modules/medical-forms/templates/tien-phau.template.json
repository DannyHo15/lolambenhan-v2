        {
          "id": "nyha-class",
          "name": "nyhaClass",
          "label": "Phân Loại NYHA (nếu có suy tim)",
          "type": "radio",
          "order": 2,
          "required": false,
          "width": "full",
          "conditionalDisplay": {
            "operator": "OR",
            "conditions": [
              { "fieldId": "heartDisease", "operator": "contains", "value": "heart-failure" }
            ]
          },
          "options": [
            { "value": "nyha1", "label": "NYHA I: Không hạn chế hoạt động" },
            { "value": "nyha2", "label": "NYHA II: Hạn chế nhẹ" },
            { "value": "nyha3", "label": "NYHA III: Hạn chế nặng" },
            { "value": "nyha4", "label": "NYHA IV: Không thể thực hiện bất kỳ hoạt động nào" }
          ],
          "columns": 1
        },
        {
          "id": "cardiac-notes",
          "name": "cardiacNotes",
          "label": "Ghi Chú Tim Mạch",
          "type": "textarea",
          "order": 3,
          "required": false,
          "width": "full",
          "maxLength": 500
        }
      ]
    },
